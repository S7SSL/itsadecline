# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Note: Stripe Identity verification uses the existing STRIPE_SECRET_KEY and STRIPE_WEBHOOK_SECRET.
# No additional env vars are required. Ensure your Stripe webhook is subscribed to:
#   - checkout.session.completed
#   - identity.verification_session.verified

# Resend (email delivery)
RESEND_API_KEY=re_...

# n8n
N8N_WEBHOOK_URL=https://your-n8n.cloud/webhook/itsadecline

# Google Drive (service account JSON, base64 or raw)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}
GOOGLE_DRIVE_CASES_FOLDER_ID=your-google-drive-folder-id-for-Cases
